PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/trend_domains?schema=public
REDIS_URL=redis://redis:6379

# AI provider. Use "ollama" to call your own Ollama server directly.
AI_PROVIDER=openai

# OpenAI-compatible provider config. DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=deepseek-chat

# Ollama native provider config. Example VPS URL: http://YOUR_VPS_IP:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

PRODUCT_HUNT_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

ENABLE_PRODUCT_HUNT=true
ENABLE_TECHCRUNCH=true
ENABLE_REDDIT=true
ENABLE_HACKERNEWS=true
ENABLE_GITHUB_TRENDING=true
ENABLE_TWITTER=false
ENABLE_GOOGLE_TRENDS=true
ENABLE_GOOGLE_AUTOCOMPLETE=true
ENABLE_GOOGLE_SERP=false
ENABLE_NAMEBIO=true
ENABLE_HUGGINGFACE=true
ENABLE_NPM=true
ENABLE_PYPI=true
ENABLE_APP_STORE=true
ENABLE_TIKTOK_CREATIVE_CENTER=true
ENABLE_SOCIAL_HANDLE_CHECK=false

GOOGLE_TRENDS_GEO=US
APP_STORE_COUNTRY=us
DEFAULT_SUBREDDITS=artificial,startups,SaaS,entrepreneur,technology,LocalLLaMA,gamedev,gaming,crypto,webdev,SideProject
MAX_DOMAINS_PER_NARRATIVE=25
MIN_BUY_SCORE=80
MIN_WATCH_SCORE=65
REQUEST_TIMEOUT_MS=15000
COLLECT_LIMIT_PER_SOURCE=30
