    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "prisma": "^5.22.0",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
